{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.6.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "min(up{job=\"market-relayer-go\",instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "title": "Scrape Up",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(max by (market) (market_relayer_publishability_state{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\",status=\"unavailable\"} == 1)) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Unavailable Markets",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.25
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(market_relayer_phase_latency_seconds_bucket{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\",phase=\"publish\"}[$__rate_interval])))",
          "refId": "A"
        }
      ],
      "title": "Publish Latency P95",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "market_relayer_source_freshness_seconds{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}",
          "legendFormat": "{{market}} {{source}} ({{basis_kind}}) @ {{instance}}",
          "refId": "A"
        }
      ],
      "title": "Source Freshness",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, phase) (rate(market_relayer_phase_latency_seconds_bucket{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval])))",
          "legendFormat": "{{phase}} p95",
          "refId": "A"
        }
      ],
      "title": "Phase Latency P95 By Phase",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      },
      "targets": [
        {
          "expr": "max by (market, status, reason) (market_relayer_publishability_state{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"} == 1)",
          "legendFormat": "{{market}} {{status}} / {{reason}}",
          "refId": "A"
        }
      ],
      "title": "Publishability State",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (market, reason) (increase(market_relayer_publishability_transitions_total{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval]))",
          "legendFormat": "transition {{market}} / {{reason}}",
          "refId": "A"
        },
        {
          "expr": "sum by (market) (increase(market_relayer_store_failures_total{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval]))",
          "legendFormat": "store {{market}}",
          "refId": "B"
        }
      ],
      "title": "Publishability And Store Events",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (market, source, reason) (increase(market_relayer_rejected_updates_total{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval]))",
          "legendFormat": "reject {{market}} {{source}} / {{reason}}",
          "refId": "A"
        },
        {
          "expr": "sum by (market, source) (increase(market_relayer_quote_freeze_events_total{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval]))",
          "legendFormat": "freeze {{market}} {{source}}",
          "refId": "B"
        },
        {
          "expr": "sum by (market, source) (increase(market_relayer_rate_limit_cooldowns_total{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval]))",
          "legendFormat": "cooldown {{market}} {{source}}",
          "refId": "C"
        }
      ],
      "title": "Source Health Events",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "id": 9,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (market) (increase(market_relayer_oracle_clamp_events_total{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval]))",
          "legendFormat": "clamp {{market}}",
          "refId": "A"
        },
        {
          "expr": "sum by (market) (increase(market_relayer_tick_overruns_total{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval]))",
          "legendFormat": "tick {{market}}",
          "refId": "B"
        },
        {
          "expr": "sum by (market) (increase(market_relayer_retry_budget_exhausted_total{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval]))",
          "legendFormat": "retry {{market}}",
          "refId": "C"
        },
        {
          "expr": "sum by (market) (increase(market_relayer_recovery_replays_total{job=\"market-relayer-go\",instance=~\"$instance\",market=~\"$market\"}[$__rate_interval]))",
          "legendFormat": "replay {{market}}",
          "refId": "D"
        }
      ],
      "title": "Loop, Publish, And Recovery Events",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["market-relayer-go", "local-ops", "observability"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": false,
        "name": "instance",
        "options": [],
        "query": "label_values(up{job=\"market-relayer-go\"}, instance)",
        "refresh": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "hide": 0,
        "includeAll": true,
        "label": "Market",
        "multi": false,
        "name": "market",
        "options": [],
        "query": "label_values(market_relayer_phase_latency_seconds_count{job=\"market-relayer-go\",instance=~\"$instance\"}, market)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "market-relayer-go Local Ops",
  "uid": "market-relayer-go-local-ops",
  "version": 2,
  "weekStart": ""
}
