MARKET_RELAYER_IMAGE=market-relayer-go:latest
MARKET_RELAYER_STORE_DSN=postgres://postgres:postgres@db.example.com:5432/market_relayer?sslmode=require
MARKET_RELAYER_STORE_MAX_OPEN_CONNS=8
MARKET_RELAYER_STORE_MAX_IDLE_CONNS=8
MARKET_RELAYER_STORE_CONN_MAX_LIFETIME=30m
MARKET_RELAYER_STORE_CONNECT_TIMEOUT=5s
MARKET_RELAYER_STORE_LOCK_TIMEOUT=5s
MARKET_RELAYER_STORE_LEASE_TTL=15s
MARKET_RELAYER_STORE_LEASE_RENEW_INTERVAL=5s
MARKET_RELAYER_SINK_URL=https://publisher.example.com/publish
MARKET_RELAYER_SINK_BEARER_TOKEN=
